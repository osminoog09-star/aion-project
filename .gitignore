# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AION driver module (inside monorepo)
/aion-driver/node_modules
/aion-driver/.expo
/aion-driver/android
/aion-driver/ios
/aion-driver/dist
/aion-driver/.tmp-eas-artifact*
.tmp-eas-art/
.tmp-eas-art.zip
.tmp-eas-artifact/
.tmp-eas-artifact.zip
# one-off debug scripts (never commit)
scripts/_tmp-*.mjs
_tmp-*.mjs
eas-build-error.json
.tmp-eas-wait.log
