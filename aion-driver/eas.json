{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "channel": "development",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_APK_MANIFEST_URL": "https://aion-com.vercel.app/apk-manifest.preview.json",
        "EXPO_PUBLIC_AION_PORTAL_URL": "https://aion-com.vercel.app"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-ota": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_OTA_PREVIEW_TEST": "1",
        "EXPO_PUBLIC_APK_MANIFEST_URL": "https://aion-com.vercel.app/apk-manifest.preview.json",
        "EXPO_PUBLIC_AION_PORTAL_URL": "https://aion-com.vercel.app"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
