{
  "name": "aion-driver",
  "version": "1.0.9",
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition",
          "fs-extra"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:offline": "expo start --web --offline",
    "eas:login": "npx eas-cli@latest login",
    "eas:whoami": "npx eas-cli@latest whoami",
    "eas:preview": "npx eas-cli@latest build -p android --profile preview",
    "eas:preview-ota": "npx eas-cli@latest build -p android --profile preview-ota",
    "eas:production": "npx eas-cli@latest build -p android --profile production",
    "eas:update:preview": "npx eas-cli@latest update --branch preview --message \"OTA preview\"",
    "eas:update:production": "npx eas-cli@latest update --branch production --message \"OTA production\"",
    "eas:update:preview:channel": "npx eas-cli@latest update --channel preview --message \"OTA preview\"",
    "eas:update:production:channel": "npx eas-cli@latest update --channel production --message \"OTA production\"",
    "ota:publish:preview": "npx eas-cli@latest update --channel preview --message \"OTA preview\"",
    "push:preview": "git push -u origin HEAD:preview",
    "push:main": "git push -u origin HEAD:main",
    "ota:preview": "npx eas-cli@latest update --channel preview --message \"OTA preview (local CLI)\"",
    "ota:production": "npx eas-cli@latest update --channel production --message \"OTA production (local CLI)\"",
    "typecheck": "tsc --noEmit",
    "repo:verify": "node scripts/ci/verify-repo-safety.mjs",
    "repo:verify:push": "node scripts/ci/verify-repo-safety.mjs --strict",
    "validate": "npm run typecheck && npm run repo:verify && npx expo-doctor && node scripts/ci/verify-no-local-eas-cli.mjs",
    "auth:google-setup": "node scripts/print-google-oauth-setup.mjs",
    "validate:code": "npm run typecheck && npm run test:field-validation && npm run test:shift-economics && npm run test:history-correction && npm run test:fgs-heartbeat && npm run test:stop-zone && npm run test:background-gate && npm run test:ota-manifest && npm run test:ocr-confirmation && node scripts/ci/verify-no-local-eas-cli.mjs",
    "build:manifest": "node scripts/generate-build-manifest.mjs",
    "native:check": "node scripts/detect-native-change.mjs",
    "test:field-validation": "node scripts/ci/test-route-field-validation.mjs",
    "test:shift-economics": "node scripts/ci/test-shift-display-economics.mjs",
    "test:history-correction": "node scripts/ci/test-historical-shift-correction.mjs",
    "test:fgs-heartbeat": "node scripts/ci/test-fgs-heartbeat.mjs",
    "test:stop-zone": "node scripts/ci/test-stop-zone-progress.mjs",
    "test:background-gate": "node scripts/ci/test-background-gate.mjs",
    "test:ota-manifest": "node scripts/ci/test-ota-manifest-summary.mjs",
    "test:ocr-confirmation": "node scripts/ci/test-ocr-confirmation.mjs",
    "ship:preview": "node scripts/dev/ship.mjs preview",
    "ship:main": "node scripts/dev/ship.mjs main",
    "release:preview": "node scripts/dev/ship.mjs preview --local-ota",
    "release:production": "node scripts/dev/ship.mjs main",
    "ship:dry": "node scripts/dev/ship.mjs preview --dry-run --no-push",
    "dev:git-status": "git status -sb",
    "env:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/diagnose-node-env.ps1",
    "doctor": "npx expo-doctor",
    "expo:config": "npx expo config --type public",
    "build:preview": "npm run validate && npx eas-cli@latest build -p android --profile preview --non-interactive",
    "build:preview:wait": "npm run validate && npx eas-cli@latest build -p android --profile preview --non-interactive --wait"
  },
  "dependencies": {
    "@expo/env": "~0.4.2",
    "@expo/metro-runtime": "^4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-ml-kit/text-recognition": "^1.5.2",
    "@sentry/react-native": "~6.10.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/query-async-storage-persister": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.100.10",
    "expo": "~52.0.23",
    "expo-apple-authentication": "~7.1.3",
    "expo-auth-session": "~6.0.3",
    "expo-blur": "~14.0.1",
    "expo-camera": "~16.0.18",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.3",
    "expo-crypto": "~14.0.2",
    "expo-document-picker": "~13.0.3",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-intent-launcher": "~12.0.2",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.3",
    "expo-localization": "~16.0.1",
    "expo-location": "~18.0.4",
    "expo-navigation-bar": "~4.0.9",
    "expo-router": "~4.0.11",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.18",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.6",
    "expo-task-manager": "~12.0.6",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "~14.0.2",
    "fs-extra": "^11.3.5",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.19.13",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "~12.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.3.3"
  }
}
