# Canonical public origin (no trailing slash). Production: https://www.aion.com (see DOMAIN.md).
# On Vercel, you can omit this initially — the app falls back to https://VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Same JSON as AION Driver EXPO_PUBLIC_APK_MANIFEST_URL — optional; enables live manifest on /releases
NEXT_PUBLIC_APK_MANIFEST_URL=

# Supabase (same project as AION Driver) — enables cloud merge + Realtime on portal
# Keys: Supabase Dashboard → Project Settings → API (Project URL + anon / publishable key)
NEXT_PUBLIC_SUPABASE_URL=https://eclrkusmwcrtnxqhzpky.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Operations owner panel (≥16 chars) — unlocks /operations/priorities edit
OPERATIONS_OWNER_SECRET=
# Local dev: write src/content/*.json on save (set 0 on read-only Vercel)
OPERATIONS_ALLOW_FS_WRITE=1
# Optional: persist priority edits to Supabase ecosystem_public_snapshots
OPERATIONS_SUPABASE_SERVICE_ROLE_KEY=
# Live execution runtime on /operations/live (Supabase + agent push from Cursor)
EXECUTION_LIVE_PUSH_URL=https://aion-com.vercel.app/api/operations/execution-live-sync

