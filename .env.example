# Canonical public origin (no trailing slash). Production: https://www.aion.com (see DOMAIN.md).
# On Vercel, you can omit this initially — the app falls back to https://VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Same JSON as AION Driver EXPO_PUBLIC_APK_MANIFEST_URL — optional; enables live manifest on /releases
NEXT_PUBLIC_APK_MANIFEST_URL=

# Supabase (same project as AION Driver) — enables cloud merge + Realtime on portal
# Keys: Supabase Dashboard → Project Settings → API (Project URL + anon / publishable key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Future ---
# NEXT_PUBLIC_REALTIME_WS_URL=
# NEXT_PUBLIC_RELEASES_API_URL=
# NEXT_PUBLIC_OPERATIONS_FEED_URL=
