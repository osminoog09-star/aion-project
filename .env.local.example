# Скопируйте в .env.local (файл в .gitignore — не коммитить).
# Cursor Agent читает это при npm run execution:autonomous-gha и ci:eas:diagnostic.

# GitHub PAT: scope repo + workflow (для dispatch EAS Build Driver preview)
GITHUB_TOKEN=

# Expo access token (локальный eas build:view / sync манифеста после FINISHED)
EXPO_TOKEN=

# Портал live-sync (уже используется execution:push-live)
OPERATIONS_OWNER_SECRET=

# Vercel production: heartbeat read (anon) + write (service role)
